  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.12.3",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
